<main class="container" style="padding-top: var(--spacing-xl); padding-bottom: var(--spacing-xl); min-height: 60vh; text-align: center;">
  <h1 style="font-size: 6rem; font-weight: 900; margin-bottom: 0; color: var(--primary);">404</h1>
  <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Page Not Found</h2>
  <p style="color: var(--text-muted); margin-bottom: 2rem;">The page you're looking for doesn't exist or has been moved.</p>
  <a href="{{ routes.root_url }}" class="btn btn-primary">&larr; Back to Home</a>
</main>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "settings": []
}
{% endschema %}
