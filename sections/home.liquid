<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (!window.KalaaData) return;
    const data = window.KalaaData;

    function createProductCard(prod) {
      const card = document.createElement('a');
      card.href = '/products/' + prod.id;
      card.className = 'product-card';
      card.innerHTML =
        (prod.badge ? '<div class="product-badge">' + prod.badge + '</div>' : '') +
        '<div class="product-img-wrapper skeleton">' +
          '<img src="' + prod.image + '" alt="' + prod.name + '" loading="lazy" onload="this.parentElement.classList.remove(\'skeleton\')">' +
        '</div>' +
        '<div class="product-info">' +
          '<h3 class="product-name">' + prod.name + '</h3>' +
          '<div class="product-price">Starting at <span>₹' + prod.price + '</span></div>' +
        '</div>';
      return card;
    }

    function fillTrack(trackId, products) {
      const track = document.getElementById(trackId);
      if (!track) return;
      track.innerHTML = '';
      products.forEach(p => track.appendChild(createProductCard(p)));
    }

    fillTrack('pop-carousel-track', data.PRODUCTS.filter(p =>
      ['business-cards','premium-visiting-cards','letterheads','envelopes','self-inking-stamps','sheet-stickers'].includes(p.id)));

    fillTrack('trend-carousel-track', data.PRODUCTS.filter(p =>
      ['business-cards','premium-visiting-cards','flyers','sheet-stickers','posters-cars','retro-prints'].includes(p.id)));

    fillTrack('stickers-carousel-track', data.PRODUCTS.filter(p => p.category === 'stickers-labels').slice(0, 8));

    fillTrack('posters-carousel-track', data.PRODUCTS.filter(p => p.category === 'posters').slice(0, 8));

    fillTrack('gift-carousel-track', data.PRODUCTS.filter(p => p.category === 'gifting'));

    fillTrack('new-carousel-track', data.PRODUCTS.filter(p =>
      ['self-inking-stamps','brochures','backlit-transline','nfc-cards','clothing-tags','event-tickets'].includes(p.id)));

    function setupCarouselButtons(prevId, nextId, wrapperId) {
      const prev = document.getElementById(prevId);
      const next = document.getElementById(nextId);
      const wrapper = document.getElementById(wrapperId);
      if (prev && next && wrapper) {
        prev.addEventListener('click', () => wrapper.scrollBy({ left: -400, behavior: 'smooth' }));
        next.addEventListener('click', () => wrapper.scrollBy({ left: 400, behavior: 'smooth' }));
      }
    }

    setupCarouselButtons('pop-prev', 'pop-next', 'pop-carousel-wrapper');
    setupCarouselButtons('trend-prev', 'trend-next', 'trend-carousel-wrapper');
    setupCarouselButtons('stickers-prev', 'stickers-next', 'stickers-carousel-wrapper');
    setupCarouselButtons('posters-prev', 'posters-next', 'posters-carousel-wrapper');
    setupCarouselButtons('gift-prev', 'gift-next', 'gift-carousel-wrapper');
    setupCarouselButtons('new-prev', 'new-next', 'new-carousel-wrapper');
  });
</script>

