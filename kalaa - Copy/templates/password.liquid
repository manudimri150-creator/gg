<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body style="display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--bg,#fff); font-family:sans-serif;">
  <div style="text-align:center; padding:2rem;">
    <h1 style="font-size:2rem; margin-bottom:1rem;">Kalaa Print &amp; Pack</h1>
    <p style="color:#666;">We're getting ready. Check back soon!</p>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <div style="margin-top:1.5rem; display:flex; gap:0.5rem; justify-content:center;">
        <input type="password" name="password" placeholder="Enter password" style="padding:0.6rem 1rem; border:1px solid #ccc; border-radius:6px;">
        <button type="submit" style="padding:0.6rem 1.2rem; background:#7c3aed; color:#fff; border:none; border-radius:6px; cursor:pointer;">Enter</button>
      </div>
    {% endform %}
  </div>
</body>
</html>
